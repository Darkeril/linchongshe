PORT= '8991'

# 开发环境配置
VITE_ENV = 'development'

# 开发环境
VITE_APP_BASE_API = '/dev-api'

# 路由懒加载
VITE_CLI_BABEL_TRANSPILE_MODULES = true

# 启用后：业务路由由 /system/menu/getRouters 动态注册（与 RuoYi 菜单一致）
VITE_MENU_FROM_SERVER = true

# Nacos 控制台（系统工具 - Nacos 页 iframe）；不配则开发环境默认 localhost:8848
VITE_APP_NACOS_URL = http://localhost:8848/nacos
