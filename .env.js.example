/**
 * 主站 uni-app 环境配置
 * 切换环境：改下方 ENV 为 'dev' | 'prod'
 */
const ENV = 'dev'

/** 服务器地址 */
const SITE_HOST = 'your-server-ip:port'
const HTTP_ORIGIN = `http://${SITE_HOST}`
const WS_ORIGIN = `ws://${SITE_HOST}`

const ENV_CONFIG = {
	dev: {
		baseUrl: 'http://localhost:80/dev-api',
		imWsUrl: 'ws://localhost:8080/web/ws/',
		aiWsUrl: 'ws://localhost:8080/chat',
	},
	prod: {
		baseUrl: `${HTTP_ORIGIN}/prod-api`,
		imWsUrl: `${WS_ORIGIN}/web/ws/`,
		aiWsUrl: `${WS_ORIGIN}/chat`,
	},
}

const currentEnv = ENV_CONFIG[ENV] || ENV_CONFIG.dev
if (!ENV_CONFIG[ENV]) {
	console.warn(`[.env.js] 未知 ENV "${ENV}"，已使用 dev 配置`)
}

const baseUrl = currentEnv.baseUrl
const imWsUrl = currentEnv.imWsUrl
const aiWsUrl = currentEnv.aiWsUrl

/** 高德 Key */
const AMAP_KEY = 'your-amap-key'
const AMAP_SECURITY_JS_CODE = ''

if (ENV === 'dev') {
	console.log('[uniapp_hongshu] 环境: dev')
	console.log('  baseUrl:', baseUrl)
	console.log('  imWsUrl:', imWsUrl)
	console.log('  aiWsUrl:', aiWsUrl)
}

export { baseUrl, imWsUrl, aiWsUrl, AMAP_KEY, AMAP_SECURITY_JS_CODE }
