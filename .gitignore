# 依赖
**/node_modules/
**/npm-debug.log*
**/yarn-debug.log*

# 构建输出
**/dist/
**/target/
**/unpackage/dist/

# 保留 App 图标
!**/unpackage/res/

# 开发工具
**/.vscode/
**/.idea/
**/*.swp
**/*.swo

# 系统文件
**/.DS_Store
**/Thumbs.db

# 日志
**/*.log

# 临时文件
**/*.tmp
**/*.temp

# 环境变量 / 敏感配置
.env
**/.env.js
**/.env.local
**/.env.*.local

# Java / Maven
**/*.class
**/*.jar
!**/lib/*.jar

# 大文件（超过 GitHub 100MB 限制）
**/*.sql

# 缓存
**/.cache/
**/.parcel-cache/
**/.eslintcache
