	"globalStyle": {
		"navigationBarTitleText": "爱宠社",
		"navigationBarTextStyle": "black",
		/* #ifndef MP-WEIXIN */
		"navigationStyle": "custom",
		/* #endif */
		/* #ifdef MP-WEIXIN */
		"navigationStyle": "default",
		/* #endif */
		"navigationBarBackgroundColor": "#F4EDE2",
		"backgroundColor": "#F4EDE2"
	},
	"uniIdRouter": {}
}
